{
  "name": "io-bot-soul",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "db:migrate": "tsx src/db/migrate.ts",
    "scheduled:post-draw": "tsx src/scheduled.ts post-draw",
    "scheduled:post-draw:prod": "node dist/scheduled.js post-draw",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "dotenv": "^16.5.0",
    "pg": "^8.20.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.3",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^3.1.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  }
}
