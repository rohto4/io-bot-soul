{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",

  // Chutes-only 設定（OpenAI なし）。
  // 評価ソース: ../chutes-model-compare/models-compact.html (43モデル)

  "default_run_agent": "sisyphus",

  "runtime_fallback": {
    "enabled": true,
    "retry_on_errors": [400, 429, 503, 529],
    "max_fallback_attempts": 3,
    "cooldown_seconds": 60,
    "timeout_seconds": 30,
    "notify_on_fallback": true
  },

  "background_task": {
    "defaultConcurrency": 6,
    "staleTimeoutMs": 420000,
    "providerConcurrency": {
      "chutes": 12
    }
  },

  "model_capabilities": {
    "enabled": true,
    "auto_refresh_on_start": true,
    "refresh_timeout_ms": 5000,
    "source_url": "https://models.dev/api.json"
  },

  "hashline_edit": true,

  // --- Agents ---

  // Conductor: 最大規模モデルで全体統括
  "agents": {
    "sisyphus": {
      "model": "chutes/qwen3-5-397b-tee",
      "fallback_models": [
        "chutes/kimi-k2.5-tee",
        "chutes/qwen3-235b-instruct-tee",
        "chutes/qwen3-32b-tee"
      ]
    },

    // Main implementer: コーディング特化
    "hephaestus": {
      "model": "chutes/qwen3-coder-next-tee",
      "fallback_models": [
        "chutes/qwen3-32b-tee",
        "chutes/deepseek-v3.2-tee",
        "chutes/kimi-k2.5-tee"
      ]
    },

    // Planner: Thinking 特化で計画立案
    "prometheus": {
      "model": "chutes/qwen3-235b-thinking",
      "fallback_models": [
        "chutes/deepseek-r1-0528-tee",
        "chutes/glm-4.7-tee",
        "chutes/qwen3-32b-tee"
      ],
      "prompt_append": "Always propose a verifiable plan (files, commands, success criteria)."
    },

    // Read-only architecture/debug: 深い推論
    "oracle": {
      "model": "chutes/deepseek-r1-0528-tee",
      "fallback_models": [
        "chutes/glm-4.7-tee",
        "chutes/qwen3-235b-instruct-tee",
        "chutes/qwen3-32b-tee"
      ],
      "permission": { "edit": "deny" }
    },

    // Cheap internal exploration: 超軽量
    "explore": {
      "model": "chutes/gemma-3-4b"
    },

    // External research / web: 高速
    "librarian": {
      "model": "chutes/qwen3-next-80b",
      "fallback_models": ["chutes/qwen3-32b-tee"]
    },

    // Images / UI screenshots: ビジョン
    "multimodal-looker": {
      "model": "chutes/kimi-k2.5-tee",
      "fallback_models": [
        "chutes/glm-4.6v",
        "chutes/qwen2-5-vl-32b"
      ]
    },

    // Pre-planning consultant: 推論系
    "metis": {
      "model": "chutes/deepseek-r1-0528-tee",
      "fallback_models": [
        "chutes/tng-r1t2-chimera-tee",
        "chutes/glm-4.7-tee",
        "chutes/qwen3-32b-tee"
      ],
      "permission": { "edit": "deny" }
    },

    // Plan review / QA
    "momus": {
      "model": "chutes/qwen3-32b-tee",
      "fallback_models": [
        "chutes/tng-r1t2-chimera-tee",
        "chutes/glm-4.7-tee"
      ],
      "permission": { "edit": "deny" }
    },

    // Documentation / longform: 長文脈モデル
    "atlas": {
      "model": "chutes/minimax-m2.5-tee",
      "fallback_models": [
        "chutes/kimi-k2.5-tee",
        "chutes/qwen3-32b-tee"
      ]
    }
  },

  // --- Categories ---
  "categories": {
    "quick": {
      "model": "chutes/gemma-3-4b",
      "description": "Single-file small changes / quick checks"
    },

    "unspecified-low": {
      "model": "chutes/gemma-3-4b",
      "description": "Low-effort tasks, short analysis"
    },

    "unspecified-high": {
      "model": "chutes/qwen3-32b-tee",
      "fallback_models": [
        "chutes/deepseek-v3.2-tee",
        "chutes/kimi-k2.5-tee",
        "chutes/qwen3-235b-instruct-tee"
      ],
      "description": "High-effort implementation and debugging"
    },

    "deep": {
      "model": "chutes/deepseek-r1-0528-tee",
      "fallback_models": [
        "chutes/qwen3-235b-thinking",
        "chutes/glm-4.7-tee"
      ],
      "description": "Thorough investigation before acting"
    },

    "ultrabrain": {
      "model": "chutes/qwen3-5-397b-tee",
      "fallback_models": [
        "chutes/deepseek-r1-0528-tee",
        "chutes/qwen3-235b-thinking",
        "chutes/kimi-k2.5-tee"
      ],
      "description": "Hard architecture / debugging"
    },

    "writing": {
      "model": "chutes/minimax-m2.5-tee",
      "fallback_models": [
        "chutes/kimi-k2.5-tee",
        "chutes/qwen3-32b-tee"
      ],
      "description": "Docs / proposals / summaries"
    },

    "visual-engineering": {
      "model": "chutes/kimi-k2.5-tee",
      "fallback_models": [
        "chutes/glm-4.6v",
        "chutes/qwen2-5-vl-32b"
      ],
      "description": "UI/UX / visual inspection"
    }
  }
}
